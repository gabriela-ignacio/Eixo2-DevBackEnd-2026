<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ControlaCar</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mf_dev_backend_2026.styles.css" asp-append-version="true" />

    <style>
            /* Ajuste opcional para navbar dark */
            .navbar-dark-custom {
                background-color: #111827;
                border-bottom: 1px solid rgba(255,255,255,0.1);
            }

                .navbar-dark-custom .nav-link,
                .navbar-dark-custom .navbar-brand {
                    color: #e5e7eb !important;
                }

                    .navbar-dark-custom .nav-link:hover {
                        color: #3b82f6 !important;
                    }

            .btn-cadastre {
                background-color: #2563eb;
                color: white !important;
                border-radius: 6px;
                padding: 6px 14px;
                transition: 0.2s;
            }

                .btn-cadastre:hover {
                    background-color: #1d4ed8;
                }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom shadow-sm mb-3">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold text-light" asp-controller="Home" asp-action="Index">
                    ControlaCar
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- MENU ESQUERDO -->
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index">Início</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Veiculos" asp-action="Index">Veículos</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Consumos" asp-action="Index">Consumos</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Usuarios" asp-action="Index">Usuários</a>
                            </li>
                        }
                    </ul>

                    <!-- MENU DIREITO -->
                    <ul class="navbar-nav">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="me-2 text-light">Olá, @User.Identity.Name!</span>
                                <a class="nav-link text-danger" asp-controller="Usuarios" asp-action="Logout">Sair</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Usuarios" asp-action="Login">Login</a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary ms-2 px-3" asp-controller="Usuarios"  asp-action="Create">
                                    Cadastre-se
                                </a>

                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>

    </header>

    <!-- CONTEÚDO -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- RODAPÉ -->
    <footer class="border-top footer bg-dark text-light mt-4 py-3">
        <div class="container text-center">
            Microfundamento de Desenvolvimento Back-End; Eixo 2 - 2026
        </div>
    </footer>


    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
